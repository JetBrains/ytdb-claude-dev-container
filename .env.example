# ─────────────────────────────────────────────────────────────────────────────
# Claude Code Docker — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic auth is handled by Claude Code's interactive login on first run.
# The credentials are persisted in the claude-data Docker volume.

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token — used for git HTTPS credentials and gh CLI
# Needs at minimum: repo, read:org scopes
GITHUB_TOKEN=

# ── Git Identity ─────────────────────────────────────────────────────────────
GIT_USER_NAME=
GIT_USER_EMAIL=

# ── Optional ─────────────────────────────────────────────────────────────────
# Override Maven local repo path (default: ~/.m2)
# MAVEN_REPO=~/.m2

# Set to run a prompt non-interactively (container exits when done)
# CLAUDE_TASK=Fix all failing tests in the core module

# DNS firewall — restrict outbound to whitelisted domains only (default: true)
# Set to false to allow unrestricted network access
# DNS_FIREWALL=false

# Extra allowed domains (comma-separated, appended to allowed-domains.txt)
# EXTRA_ALLOWED_DOMAINS=example.com,cooldb.io

# CPU limit — max CPUs the container may use (default: 85% of host CPUs)
# Set to 0 for unlimited
# CPU_LIMIT=13.6
