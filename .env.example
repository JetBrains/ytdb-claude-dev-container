# ─────────────────────────────────────────────────────────────────────────────
# Claude Code Docker — Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ─────────────────────────────────────────────────────────────────
# Anthropic auth is handled by Claude Code's interactive login on first run.
# The credentials are persisted in the claude-data Docker volume.

# ── GitHub ───────────────────────────────────────────────────────────────────
# Personal Access Token — used for git HTTPS credentials and gh CLI
# Needs at minimum: repo, read:org scopes
GITHUB_TOKEN=

# ── Git Identity ─────────────────────────────────────────────────────────────
GIT_USER_NAME=
GIT_USER_EMAIL=

# ── Optional ─────────────────────────────────────────────────────────────────
# Override Maven local repo path (default: ~/.m2)
# MAVEN_REPO=~/.m2

# Set to run a prompt non-interactively (container exits when done)
# CLAUDE_TASK=Fix all failing tests in the core module
